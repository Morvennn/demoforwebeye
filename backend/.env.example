# ===== MiniMax (OpenAI-compatible) =====
# Get from your MiniMax coding plan / platform dashboard.
MINIMAX_API_KEY=your_minimax_api_key_here
# China platform key (platform.minimaxi.com) -> api.minimaxi.com
# International key -> api.minimax.io
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M3

# ===== GitHub (optional but recommended) =====
# Raises rate limit from 60/h to 5000/h. Create a classic PAT with public_repo read.
GITHUB_TOKEN=

# ===== CORS (frontend origin allowed to call the API) =====
# Use * for local dev, or your deployed frontend URL in production.
CORS_ORIGIN=*
